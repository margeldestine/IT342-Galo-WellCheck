<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Navbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="#F8F7F4"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  WellCheck"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

            </LinearLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Login"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0F000000" />

        <!-- Hero content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <!-- Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guidance &amp; Wellness Platform"
                    android:textSize="12sp"
                    android:textColor="#1F7A5A"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Hero title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Book counseling appointments "
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="0dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="securely."
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1F7A5A"
                android:layout_marginBottom="16dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect with professional counselors who understand student life. Schedule appointments that fit your schedule and take control of your mental wellness journey."
                android:textSize="14sp"
                android:textColor="#666666"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="32dp" />

            <!-- Feature cards -->
            <!-- Card 1: Secure & Confidential (Green) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_green"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card_icon_white"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="20sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Secure &amp; Confidential"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All appointments and conversations are protected with enterprise-grade encryption."
                    android:textSize="13sp"
                    android:textColor="#CCFCE8"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Card 2: Easy Scheduling (White) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card_icon_green"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="20sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Easy Scheduling"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Browse available counselors and book your slot in just a few clicks."
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Card 3: Instant Notifications (White) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card_icon_green"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="20sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instant Notifications"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Get notified via email when your appointment is approved or rejected."
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confidential"
                        android:textSize="12sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24/7"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking access"
                        android:textSize="12sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fast"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Approval process"
                        android:textSize="12sp"
                        android:textColor="#999999" />
                </LinearLayout>

            </LinearLayout>

            <!-- Buttons -->
            <Button
                android:id="@+id/btnSignUpStudent"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign Up as Student"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1F7A5A"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSignUpCounselor"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign Up as Counselor"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:backgroundTint="#FFFFFF"
                android:strokeColor="#E0E0E0"
                android:stateListAnimator="@null"
                android:layout_marginBottom="40dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>