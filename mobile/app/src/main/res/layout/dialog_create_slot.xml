<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create a New Slot"
            android:textColor="#1A1A1A"
            android:textSize="22sp"/>

        <TextView
            android:id="@+id/tvDialogSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Weekdays only · 8–12 AM or 1–5 PM"
            android:textColor="#888888"
            android:textSize="13sp"/>

        <!-- Date -->
        <TextView
            android:id="@+id/tvLabelDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:text="Date"
            android:textColor="#1A1A1A"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(Mon – Fri)"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPickDate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="mm/dd/yyyy"
            android:textAllCaps="false"
            android:textColor="#1A1A1A"
            app:cornerRadius="10dp"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp"/>

        <!-- Start time + Duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLabelStartTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start time"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerStartTime"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input_outline"/>
            </LinearLayout>

            <View android:layout_width="12dp" android:layout_height="0dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLabelDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duration"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerDuration"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input_outline"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Repeat Label -->
        <TextView
            android:id="@+id/tvLabelRepeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:text="Repeat"
            android:textColor="#1A1A1A"
            android:textSize="12sp"/>

        <!-- No repeat option -->
        <LinearLayout
            android:id="@+id/btnRepeatNone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/repeat_option_selected"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvRepeatNone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✕  No repeat"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Daily option -->
        <LinearLayout
            android:id="@+id/btnRepeatDaily"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/repeat_option_unselected"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvRepeatDaily"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↻  Daily (Mon – Fri)"
                android:textColor="#1A1A1A"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Weekly option -->
        <LinearLayout
            android:id="@+id/btnRepeatWeekly"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/repeat_option_unselected"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvRepeatWeekly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↺  Weekly"
                android:textColor="#1A1A1A"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Repeat Until (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutRepeatUntil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLabelRepeatUntil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:text="Repeat until"
                android:textColor="#1A1A1A"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(inclusive)"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnPickRepeatUntil"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="mm/dd/yyyy"
                android:textAllCaps="false"
                android:textColor="#1A1A1A"
                app:cornerRadius="10dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp"/>
        </LinearLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvDialogError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#E53E3E"
            android:textSize="12sp"
            android:visibility="gone"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDialogCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#888888"
                app:cornerRadius="10dp"
                app:strokeColor="#DDDDDD"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogSubmit"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="Create Slot"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1B3A2D"
                app:cornerRadius="10dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>