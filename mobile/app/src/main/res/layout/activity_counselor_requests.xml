<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4EF">

    <!-- Rich Dark Header — identical structure to dashboard/manage slots -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3A2D"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="64dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPortalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COUNSELOR PORTAL"
            android:textColor="#FFFFFF"
            android:alpha="0.5"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Appointment Requests"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="@font/dm_serif_display_italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPortalLabel"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Review and manage student appointment requests."
            android:textColor="#FFFFFF"
            android:alpha="0.6"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content overlapping header by 28dp -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-28dp"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Search bar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:hint="Search by student name..."
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:textSize="13sp"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tabs inside a card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/tabPending"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Pending"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:layout_marginEnd="3dp"/>

                    <TextView
                        android:id="@+id/tabConfirmed"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Confirmed"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:layout_marginEnd="3dp"/>

                    <TextView
                        android:id="@+id/tabRejected"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Rejected"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:layout_marginEnd="3dp"/>

                    <TextView
                        android:id="@+id/tabCancelled"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Cancelled"
                        android:gravity="center"
                        android:textSize="12sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section label + count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTabLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING REQUESTS"
                    android:textColor="#1B3A2D"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/inter_bold"/>

                <TextView
                    android:id="@+id/tvTabCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/badge_bg"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_bold"/>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"/>

            <!-- Empty state -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textColor="#D0D0D0"
                        android:textSize="28sp"
                        android:fontFamily="@font/dm_serif"/>

                    <TextView
                        android:id="@+id/tvEmptyMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_regular"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cards injected here -->
            <LinearLayout
                android:id="@+id/listContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation — matches dashboard exactly -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Dashboard"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navManageSlots"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                app:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Manage Slots"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRequests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_clipboard"
                app:tint="#1B3A2D"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Requests"
                android:textColor="#1B3A2D"
                android:textSize="10sp"
                android:fontFamily="@font/inter_bold"/>
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/shape_circle"
                android:backgroundTint="#1B3A2D"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Profile"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>