<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="48dp">

        <!-- Logo — consistent with Login + Student Register -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/wellcheck_logo"
                android:scaleType="centerInside"
                android:contentDescription="WellCheck Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WellCheck"
                android:layout_marginStart="8dp"
                android:textSize="18sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Counselor Account"
                android:textSize="24sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register to manage student appointments and availability."
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/subtitle_gray"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Error Banner -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error"
                android:textColor="@color/error_red"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Success Banner -->
            <TextView
                android:id="@+id/tvSuccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success"
                android:textColor="@color/success_green"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Section: Personal Information -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  PERSONAL INFORMATION  "
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

            </LinearLayout>

            <!-- First + Last Name Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/label_gray"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="John"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/hint_gray" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/label_gray"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Doe"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/hint_gray" />

                </LinearLayout>

            </LinearLayout>

            <!-- Section: Professional Information -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  PROFESSIONAL INFORMATION  "
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

            </LinearLayout>

            <!-- Employee Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Employee Number"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmployeeId"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="EMP-2024-12345"
                android:inputType="text"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/hint_gray"
                android:layout_marginBottom="16dp" />

            <!-- Specialization -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Specialization"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerSpecialization"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:entries="@array/specializations" />

            </FrameLayout>

            <!-- Bio -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Short Bio / Description"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Tell students about your background and approach..."
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/hint_gray"
                android:layout_marginBottom="16dp" />

            <!-- Section: Account Credentials -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ACCOUNT CREDENTIALS  "
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

            </LinearLayout>

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="johndoe@gmail.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/hint_gray"
                android:layout_marginBottom="16dp" />

            <!-- Password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Minimum 8 characters"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="52dp"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/hint_gray" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:src="@drawable/ic_eye"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle password visibility" />

            </FrameLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green_primary"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Submit Registration"
                android:textSize="15sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/green_primary"
                android:stateListAnimator="@null"
                app:cornerRadius="10dp"
                android:layout_marginBottom="20dp" />

            <!-- Sign In Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/subtitle_gray" />

                <TextView
                    android:id="@+id/tvSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>