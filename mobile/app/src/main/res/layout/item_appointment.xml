<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Main row: date box + info + status+cancel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Date box -->
            <LinearLayout
                android:id="@+id/layoutDateBox"
                android:layout_width="56dp"
                android:layout_height="64dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_date_box_green">

                <TextView
                    android:id="@+id/tvMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="#16A34A"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="#1A1A1A" />

            </LinearLayout>

            <!-- Counselor info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCounselorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tvSpecialization"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:textColor="#6B7280" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_clock"
                        app:tint="#9CA3AF" />

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"
                        android:textColor="#6B7280" />
                </LinearLayout>

            </LinearLayout>

            <!-- Right side: status badge + cancel button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:singleLine="true"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_bold" />

                <!-- Cancel: same minWidth as Pending pill -->
                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:text="Cancel"
                    android:textSize="12sp"
                    android:textColor="#DC2626"
                    android:fontFamily="@font/inter_bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:minHeight="0dp"
                    android:minWidth="68dp"
                    android:visibility="gone"
                    android:background="@drawable/bg_badge_cancelled_red" />

            </LinearLayout>

        </LinearLayout>

        <!-- Rejection reason -->
        <LinearLayout
            android:id="@+id/layoutReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_rejection_reason"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_warning"
                app:tint="#DC2626" />

            <TextView
                android:id="@+id/tvReason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                android:textColor="#DC2626" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>