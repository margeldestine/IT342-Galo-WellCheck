<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ GREEN HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_dark"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STUDENT PORTAL"
            android:textColor="#7CAF92"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/inter_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:id="@+id/tvPageTitle"
            android:text="My Profile"
            android:textColor="@color/white"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="View and update your student information."
            android:textColor="#AACFB8"
            android:textSize="13sp"
            android:fontFamily="@font/inter" />

    </LinearLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/green_dark" />

        <ScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <!-- ── Info Banner (no school ID) ── -->
                <LinearLayout
                    android:id="@+id/bannerNoId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_info_banner"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Upload your School ID to complete your profile."
                        android:textSize="12sp"
                        android:textColor="#1E40AF"
                        android:fontFamily="@font/inter" />

                </LinearLayout>

                <!-- ══ PROFILE SUMMARY CARD ══ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Green band + avatar overlap using RelativeLayout -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="102dp">

                            <!-- Green top band: top 64dp -->
                            <View
                                android:id="@+id/greenBand"
                                android:layout_width="match_parent"
                                android:layout_height="64dp"
                                android:background="@color/green_dark"
                                android:layout_alignParentTop="true" />

                            <!-- White bottom strip -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:background="@color/white"
                                android:layout_below="@id/greenBand" />

                            <!-- Avatar circle: centered, sitting on the band boundary -->
                            <TextView
                                android:id="@+id/tvInitials"
                                android:layout_width="76dp"
                                android:layout_height="76dp"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="26dp"
                                android:gravity="center"
                                android:text="MD"
                                android:textSize="26sp"
                                android:textColor="@color/white"
                                android:fontFamily="@font/inter_bold"
                                android:background="@drawable/bg_avatar_circle" />

                        </RelativeLayout>

                        <!-- Name, ID, pills, birthdate -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingHorizontal="20dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="18dp">

                            <TextView
                                android:id="@+id/tvFullName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/inter_bold" />

                            <TextView
                                android:id="@+id/tvStudentId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID: —"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"
                                android:fontFamily="@font/inter"
                                android:layout_marginTop="2dp" />

                            <!-- Pills row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp">

                                <TextView
                                    android:id="@+id/tvPillProgram"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="5dp"
                                    android:textSize="11sp"
                                    android:textColor="@color/green_dark"
                                    android:fontFamily="@font/inter"
                                    android:singleLine="true"
                                    android:background="@drawable/bg_pill_green"
                                    android:layout_marginEnd="6dp" />

                                <TextView
                                    android:id="@+id/tvPillYear"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="5dp"
                                    android:textSize="11sp"
                                    android:textColor="@color/green_dark"
                                    android:fontFamily="@font/inter"
                                    android:singleLine="true"
                                    android:background="@drawable/bg_pill_green"
                                    android:layout_marginEnd="6dp" />

                                <TextView
                                    android:id="@+id/tvPillGender"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="5dp"
                                    android:textSize="11sp"
                                    android:textColor="@color/green_dark"
                                    android:fontFamily="@font/inter"
                                    android:singleLine="true"
                                    android:background="@drawable/bg_pill_green" />

                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#F0EDE8"
                                android:layout_marginTop="14dp"
                                android:layout_marginBottom="12dp" />

                            <!-- Birthdate row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Birthdate"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_gray"
                                    android:fontFamily="@font/inter" />

                                <TextView
                                    android:id="@+id/tvBirthdate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark"
                                    android:fontFamily="@font/inter_bold" />

                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══ PERSONAL INFORMATION CARD ══ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Section label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PERSONAL INFORMATION"
                            android:textSize="10sp"
                            android:textColor="@color/green_dark"
                            android:letterSpacing="0.12"
                            android:fontFamily="@font/inter_bold"
                            android:layout_marginBottom="4dp" />

                        <!-- Thin green underline -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E5F0EB"
                            android:layout_marginBottom="16dp" />

                        <!-- Student ID -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student ID Number"
                            android:textSize="11sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/inter"
                            android:layout_marginBottom="5dp" />

                        <EditText
                            android:id="@+id/etStudentId"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="14dp"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter"
                            android:enabled="false"
                            android:layout_marginBottom="14dp" />

                        <!-- First + Last name side by side -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="First Name"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray"
                                    android:fontFamily="@font/inter"
                                    android:layout_marginBottom="5dp" />

                                <EditText
                                    android:id="@+id/etFirstName"
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_input_field"
                                    android:paddingHorizontal="14dp"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark"
                                    android:fontFamily="@font/inter"
                                    android:enabled="false" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Last Name"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray"
                                    android:fontFamily="@font/inter"
                                    android:layout_marginBottom="5dp" />

                                <EditText
                                    android:id="@+id/etLastName"
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_input_field"
                                    android:paddingHorizontal="14dp"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark"
                                    android:fontFamily="@font/inter"
                                    android:enabled="false" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Enrolled Program -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enrolled Program"
                            android:textSize="11sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/inter"
                            android:layout_marginBottom="5dp" />

                        <EditText
                            android:id="@+id/etProgram"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="14dp"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter"
                            android:enabled="false"
                            android:layout_marginBottom="14dp" />

                        <!-- Year Level + Gender side by side -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Year Level"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray"
                                    android:fontFamily="@font/inter"
                                    android:layout_marginBottom="5dp" />

                                <EditText
                                    android:id="@+id/etYearLevel"
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_input_field"
                                    android:paddingHorizontal="14dp"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark"
                                    android:fontFamily="@font/inter"
                                    android:enabled="false" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Gender"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_gray"
                                    android:fontFamily="@font/inter"
                                    android:layout_marginBottom="5dp" />

                                <EditText
                                    android:id="@+id/etGender"
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_input_field"
                                    android:paddingHorizontal="14dp"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark"
                                    android:fontFamily="@font/inter"
                                    android:enabled="false" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Birthdate -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Birthdate"
                            android:textSize="11sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/inter"
                            android:layout_marginBottom="5dp" />

                        <EditText
                            android:id="@+id/etBirthdate"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="14dp"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/inter"
                            android:enabled="false" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══ SCHOOL ID PHOTO CARD ══ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Section label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SCHOOL ID PHOTO"
                            android:textSize="10sp"
                            android:textColor="@color/green_dark"
                            android:letterSpacing="0.12"
                            android:fontFamily="@font/inter_bold"
                            android:layout_marginBottom="4dp" />

                        <!-- Thin green underline -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E5F0EB"
                            android:layout_marginBottom="14dp" />

                        <!-- Uploaded photo (hidden until loaded) -->
                        <ImageView
                            android:id="@+id/imgSchoolId"
                            android:layout_width="match_parent"
                            android:layout_height="190dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="12dp" />

                        <!-- Empty state tap target -->
                        <TextView
                            android:id="@+id/btnUploadEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:gravity="center"
                            android:text="📷  Upload School ID"
                            android:textSize="14sp"
                            android:textColor="@color/green_dark"
                            android:fontFamily="@font/inter_bold"
                            android:background="@drawable/bg_upload_empty"
                            android:visibility="gone" />

                        <!-- Action buttons row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <!-- Upload (appears after picking image) -->
                            <Button
                                android:id="@+id/btnUploadId"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:text="Upload"
                                android:textSize="13sp"
                                android:textColor="@color/white"
                                android:textAllCaps="false"
                                android:fontFamily="@font/inter_bold"
                                android:backgroundTint="@color/green_dark"
                                android:layout_marginEnd="10dp"
                                android:visibility="gone" />

                            <!-- Change Photo (appears after upload exists) -->
                            <Button
                                android:id="@+id/btnChangePhoto"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:text="Change Photo"
                                android:textSize="13sp"
                                android:textColor="@color/text_gray"
                                android:textAllCaps="false"
                                android:fontFamily="@font/inter"
                                android:backgroundTint="#F0EDE8"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- ══ BOTTOM NAV ══ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#9CA3AF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:text="Home"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCounselors"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_counselor"
                app:tint="#9CA3AF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:text="Counselors"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAppointments"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                app:tint="#9CA3AF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:text="Appointments"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/green_dark" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_bold"
                android:text="Profile"
                android:textColor="@color/green_dark"
                android:textSize="10sp" />
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/shape_circle"
                android:backgroundTint="@color/green_dark" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>