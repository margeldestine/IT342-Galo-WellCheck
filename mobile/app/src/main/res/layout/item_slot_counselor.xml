<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Date Pill (Matches image_1a5f92.png) -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_date_pill"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="MAY"
                android:textColor="@color/green_dark"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSlotDayNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_serif_display_regular"
                android:text="15"
                android:textColor="@color/text_dark"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Slot Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="10:00 AM → 10:30 AM"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvSlotDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter"
                android:text="Friday, May 15, 2026"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvSlotStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_confirmed"
            android:fontFamily="@font/inter_bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="AVAILABLE"
            android:textColor="#10B981"
            android:textSize="10sp" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnEditSlot"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_edit"
                app:tint="@color/text_gray" />

            <ImageButton
                android:id="@+id/btnDeleteSlot"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="@color/error_red" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>