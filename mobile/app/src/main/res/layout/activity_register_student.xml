<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/wellcheck_logo"
                android:scaleType="centerInside"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WellCheck"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/inter" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Login"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/text_dark"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:fontFamily="@font/inter"
                android:stateListAnimator="@null"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Medium" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Student Account"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:gravity="center"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register to book counseling appointments securely."
                android:textSize="13sp"
                android:textColor="@color/text_gray"
                android:gravity="center"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error"
                android:textColor="@color/error_red"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  PERSONAL INFORMATION  "
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.1" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Student ID Number"
                android:textSize="13sp"
                android:textColor="#444444"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etStudentId"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="2023-12345 or 23-2425-001"
                android:inputType="text"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textColorHint="#AAAAAA"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="John"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="#AAAAAA"
                        android:fontFamily="@font/inter" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Doe"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="#AAAAAA"
                        android:fontFamily="@font/inter" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enrolled Program"
                android:textSize="13sp"
                android:textColor="#444444"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerProgram"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:entries="@array/programs"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Year Level"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerYearLevel"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:entries="@array/year_levels" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gender"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:fontFamily="@font/inter"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerGender"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:entries="@array/genders" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Birthdate"
                android:textSize="13sp"
                android:textColor="#444444"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etBirthdate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Select your birthdate"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textColorHint="#AAAAAA"
                android:fontFamily="@font/inter"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:drawableEnd="@drawable/ic_calendar"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ACCOUNT CREDENTIALS  "
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.1" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textSize="13sp"
                android:textColor="#444444"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="johndoe@gmail.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textColorHint="#AAAAAA"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="13sp"
                android:textColor="#444444"
                android:fontFamily="@font/inter"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Minimum 8 characters"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="52dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:textColorHint="#AAAAAA"
                    android:fontFamily="@font/inter" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:src="@drawable/ic_eye"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle password visibility" />

            </FrameLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Create Account"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/green_primary"
                android:fontFamily="@font/inter"
                android:stateListAnimator="@null"
                android:layout_marginBottom="16dp"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  or  "
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:fontFamily="@font/inter" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sign up with Google"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/inter"
                android:stateListAnimator="@null"
                android:layout_marginBottom="20dp"
                app:icon="@drawable/ic_google"
                app:iconGravity="textStart"
                app:iconTint="@null"
                app:strokeColor="@color/border"
                app:strokeWidth="1.5dp"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:id="@+id/tvSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textSize="13sp"
                    android:textColor="@color/green_primary"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>