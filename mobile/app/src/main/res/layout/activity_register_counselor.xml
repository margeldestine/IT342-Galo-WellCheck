<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Navbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text=""
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_logo"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WellCheck"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Login"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Counselor Account"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register to manage student appointments and availability."
                android:textSize="13sp"
                android:textColor="#888888"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Error -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error"
                android:textColor="#E53E3E"
                android:textSize="13sp"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Success -->
            <TextView
                android:id="@+id/tvSuccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_success"
                android:textColor="#1F7A5A"
                android:textSize="13sp"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- PERSONAL INFORMATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E5E7EB" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  PERSONAL INFORMATION  "
                    android:textSize="11sp" android:textStyle="bold" android:textColor="#1F7A5A"
                    android:letterSpacing="0.1" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E5E7EB" />
            </LinearLayout>

            <!-- First + Last Name -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="First Name" android:textSize="13sp" android:textColor="#444444"
                        android:layout_marginBottom="6dp" />
                    <EditText android:id="@+id/etFirstName" android:layout_width="match_parent"
                        android:layout_height="48dp" android:hint="John"
                        android:inputType="textPersonName" android:background="@drawable/bg_input"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#AAAAAA" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Last Name" android:textSize="13sp" android:textColor="#444444"
                        android:layout_marginBottom="6dp" />
                    <EditText android:id="@+id/etLastName" android:layout_width="match_parent"
                        android:layout_height="48dp" android:hint="Doe"
                        android:inputType="textPersonName" android:background="@drawable/bg_input"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#AAAAAA" />
                </LinearLayout>
            </LinearLayout>

            <!-- PROFESSIONAL INFORMATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E5E7EB" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  PROFESSIONAL INFORMATION  "
                    android:textSize="11sp" android:textStyle="bold" android:textColor="#1F7A5A"
                    android:letterSpacing="0.1" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E5E7EB" />
            </LinearLayout>

            <!-- Employee Number -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Employee Number" android:textSize="13sp" android:textColor="#444444"
                android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etEmployeeId" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="EMP-2024-12345"
                android:inputType="text" android:background="@drawable/bg_input"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#AAAAAA"
                android:layout_marginBottom="16dp" />

            <!-- Specialization -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Specialization" android:textSize="13sp" android:textColor="#444444"
                android:layout_marginBottom="6dp" />
            <Spinner android:id="@+id/spinnerSpecialization" android:layout_width="match_parent"
                android:layout_height="48dp" android:background="@drawable/bg_input"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:entries="@array/specializations"
                android:layout_marginBottom="16dp" />

            <!-- Short Bio -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Short Bio / Description" android:textSize="13sp" android:textColor="#444444"
                android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etBio" android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Tell students about your background and approach..."
                android:inputType="textMultiLine" android:gravity="top"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="12dp"
                android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#AAAAAA"
                android:layout_marginBottom="16dp" />

            <!-- ACCOUNT CREDENTIALS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E5E7EB" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  ACCOUNT CREDENTIALS  "
                    android:textSize="11sp" android:textStyle="bold" android:textColor="#1F7A5A"
                    android:letterSpacing="0.1" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E5E7EB" />
            </LinearLayout>

            <!-- Email -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Email Address" android:textSize="13sp" android:textColor="#444444"
                android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etEmail" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="johndoe@gmail.com"
                android:inputType="textEmailAddress" android:background="@drawable/bg_input"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#AAAAAA"
                android:layout_marginBottom="16dp" />

            <!-- Password -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Password" android:textSize="13sp" android:textColor="#444444"
                android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etPassword" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Minimum 8 characters"
                android:inputType="textPassword" android:background="@drawable/bg_input"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#AAAAAA"
                android:layout_marginBottom="24dp" />

            <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="center"
                android:layout_marginBottom="8dp" android:visibility="gone" />

            <Button android:id="@+id/btnSubmit" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Submit Registration"
                android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:backgroundTint="#1F7A5A" android:stateListAnimator="@null"
                android:layout_marginBottom="20dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Already have an account? " android:textSize="13sp"
                    android:textColor="#888888" />
                <TextView android:id="@+id/tvSignIn" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Sign In"
                    android:textSize="13sp" android:textColor="#1F7A5A" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>