<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/rounded_input_bg"
    android:layout_marginBottom="8dp"
    android:paddingHorizontal="12dp">

    <TextView android:id="@+id/tvCredentialTitle"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textSize="14sp"
        android:textColor="@color/text_primary"/>

    <TextView android:id="@+id/tvCredentialYear"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="@color/text_secondary"
        android:layout_marginEnd="12dp"/>

    <ImageButton android:id="@+id/btnRemoveCredential"
        android:layout_width="24dp" android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@android:color/transparent"
        android:contentDescription="Remove"/>

</LinearLayout>