<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="48dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/wellcheck_logo"
                android:scaleType="centerInside"
                android:contentDescription="WellCheck Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WellCheck"
                android:layout_marginStart="8dp"
                android:textSize="18sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete Your Profile"
                android:textSize="24sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please fill in your counselor details to continue."
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/subtitle_gray"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Error Banner -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error"
                android:textColor="@color/error_red"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Section Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  COUNSELOR INFORMATION  "
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border" />

            </LinearLayout>

            <!-- Employee Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Employee Number"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmployeeNumber"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="EMP-2024-12345"
                android:inputType="text"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/hint_gray"
                android:layout_marginBottom="16dp" />

            <!-- Specialization -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Specialization"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerSpecialization"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:entries="@array/specializations" />

            </FrameLayout>

            <!-- Short Bio -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Short Bio / Description"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/label_gray"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etShortBio"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Tell students about your background and approach..."
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:lines="4"
                android:maxLines="6"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/hint_gray"
                android:layout_marginBottom="24dp" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green_primary"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Complete Profile Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Complete Profile"
                android:textSize="15sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/green_primary"
                android:stateListAnimator="@null"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>