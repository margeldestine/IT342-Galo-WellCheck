<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvStep3Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review &amp; Confirm"
            android:textColor="#1A1A1A"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvStep3Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Please review your booking details below."
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- Counselor section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="COUNSELOR"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewCounselor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewSpec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#F3F4F6" />

        <!-- Schedule section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCHEDULE"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#F3F4F6" />

        <!-- Student section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STUDENT"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReviewStudentId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- Note section (optional, hidden if empty) -->
        <LinearLayout
            android:id="@+id/layoutReviewNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#F3F4F6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTE"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReviewNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#374151"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Error message -->
        <TextView
            android:id="@+id/tvBookingError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_id_missing"
            android:padding="12dp"
            android:textColor="#92400E"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Back / Confirm buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStep3Back"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="Back"
            android:textColor="@color/green_dark"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/green_dark"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStep3Confirm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:text="Confirm Booking"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/green_dark"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>