<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Date box -->
        <LinearLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_box_green"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="0.08"
                android:textColor="#059669"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvSlotDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/green_dark"
                android:textSize="20sp" />

        </LinearLayout>

        <!-- Time + date text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvSlotDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Select button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectSlot"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:backgroundTint="@color/green_dark"
            android:fontFamily="@font/inter_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Select"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:cornerRadius="10dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>