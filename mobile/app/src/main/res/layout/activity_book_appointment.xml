<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ══ GREEN HEADER ══ -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/green_dark"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Back button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_back_btn"
                    android:src="@drawable/ic_arrow_back"
                    android:scaleType="center"
                    app:tint="@color/white" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Appointment"
                android:textColor="@color/white"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/tvMainSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <!-- Step Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp">

                <!-- Step 1 -->
                <TextView
                    android:id="@+id/tvStep1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/bg_step_active"
                    android:textColor="@color/white" />

                <!-- Line 1 -->
                <View
                    android:id="@+id/viewLine1"
                    android:layout_width="48dp"
                    android:layout_height="2dp"
                    android:background="#FFE5E7EB" />

                <!-- Step 2 -->
                <TextView
                    android:id="@+id/tvStep2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="2"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/bg_step_inactive"
                    android:textColor="#9CA3AF" />

                <!-- Line 2 -->
                <View
                    android:id="@+id/viewLine2"
                    android:layout_width="48dp"
                    android:layout_height="2dp"
                    android:background="#FFE5E7EB" />

                <!-- Step 3 -->
                <TextView
                    android:id="@+id/tvStep3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="3"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/bg_step_inactive"
                    android:textColor="#9CA3AF" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══ STEP 1: Personal Info ══ -->
        <include
            android:id="@+id/layoutStep1"
            layout="@layout/layout_book_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-24dp"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ STEP 2: School ID + Note ══ -->
        <include
            android:id="@+id/layoutStep2"
            layout="@layout/layout_book_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ STEP 3: Review ══ -->
        <include
            android:id="@+id/layoutStep3"
            layout="@layout/layout_book_step3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ STEP 4: Success ══ -->
        <include
            android:id="@+id/layoutSuccess"
            layout="@layout/layout_book_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>