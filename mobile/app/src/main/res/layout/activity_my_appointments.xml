<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ GREEN HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_dark"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STUDENT PORTAL"
            android:textColor="#7CAF92"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/inter_bold" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="My Appointments"
            android:textColor="@color/white"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="View and manage your counseling sessions."
            android:textColor="#AACFB8"
            android:textSize="13sp"
            android:fontFamily="@font/inter" />

    </LinearLayout>

    <!-- ══ FILTER TABS ══ -->
    <HorizontalScrollView
        android:id="@+id/filterTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical"
            android:divider="@null">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="All"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                app:cornerRadius="20dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabPending"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="Pending"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                app:cornerRadius="20dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabConfirmed"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="Confirmed"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                app:cornerRadius="20dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabRejected"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="Rejected"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                app:cornerRadius="20dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabCancelled"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Cancelled"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                app:cornerRadius="20dp"
                app:strokeWidth="0dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ══ CONTENT ══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/filterTabs"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/green_dark" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_calendar"
                app:tint="#D1D5DB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No appointments found"
                android:textColor="#374151"
                android:textSize="16sp"
                android:fontFamily="@font/inter_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Your appointments will appear here"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:fontFamily="@font/inter" />

        </LinearLayout>

        <!-- List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAppointments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ══ BOTTOM NAV ══ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#9CA3AF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:text="Home"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCounselors"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_counselor"
                app:tint="#9CA3AF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:text="Counselors"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAppointments"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/green_dark" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_bold"
                android:text="Appointments"
                android:textColor="@color/green_dark"
                android:textSize="10sp" />
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/shape_circle"
                android:backgroundTint="@color/green_dark" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="#9CA3AF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter"
                android:text="Profile"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>