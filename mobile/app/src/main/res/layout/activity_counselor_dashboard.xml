<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4EF">

    <!-- Rich Dark Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3A2D"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="64dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPortalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COUNSELOR PORTAL"
            android:textColor="#FFFFFF"
            android:alpha="0.5"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:text="Good morning, Counselor."
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:lineSpacingMultiplier="1.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/dateContainer"
            app:layout_constraintTop_toBottomOf="@id/tvPortalLabel"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Here is your counseling overview for today."
            android:textColor="#FFFFFF"
            android:alpha="0.6"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/dateContainer"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"/>

        <!-- Date block -->
        <LinearLayout
            android:id="@+id/dateContainer"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/rounded_date_bg"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingHorizontal="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvWelcome"
            app:layout_constraintBottom_toBottomOf="@id/tvSubtitle">

            <TextView
                android:id="@+id/tvDateDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:lineSpacingMultiplier="1.0"/>

            <View
                android:layout_width="24dp"
                android:layout_height="1dp"
                android:background="#FFFFFF"
                android:alpha="0.3"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDateMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAY 2026"
                android:textColor="#FFFFFF"
                android:alpha="0.7"
                android:textSize="8sp"
                android:letterSpacing="0.08"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-28dp"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Stat Cards Row — all 3 in one row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp">

                <!-- Pending -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/shape_rounded_box"
                            android:backgroundTint="#FFF3E0">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_clipboard"
                                app:tint="#F59E0B"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvPendingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="0"
                            android:textColor="#1A1A1A"
                            android:textSize="26sp"
                            android:fontFamily="@font/dm_serif"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Pending"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Confirmed -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/shape_rounded_box"
                            android:backgroundTint="#E8F5E9">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar"
                                app:tint="#16A34A"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvConfirmedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="0"
                            android:textColor="#1A1A1A"
                            android:textSize="26sp"
                            android:fontFamily="@font/dm_serif"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Confirmed"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total Students -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/shape_rounded_box"
                            android:backgroundTint="#E3F2FD">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile"
                                app:tint="#1E88E5"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvTotalStudentsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="0"
                            android:textColor="#1A1A1A"
                            android:textSize="26sp"
                            android:fontFamily="@font/dm_serif"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Students"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Quick Actions Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:text="QUICK ACTIONS"
                android:textColor="#1B3A2D"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="@font/inter_bold"/>

            <!-- Quick Actions Side by Side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <!-- Create Slot -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCreateSlot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#1B3A2D"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/shape_rounded_box"
                            android:backgroundTint="#2D5240">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="+"
                                android:textColor="#6FCF97"
                                android:textSize="20sp"
                                android:fontFamily="@font/inter_bold"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Create Slot"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:alpha="0.5"
                            android:fontFamily="@font/inter_regular"
                            android:text="Add a new available time slot"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Review Requests -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardReviewRequests"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/shape_rounded_box"
                            android:backgroundTint="#FFF3E0">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_clipboard"
                                app:tint="#F59E0B"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Review Requests"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:fontFamily="@font/inter_bold"/>

                        <TextView
                            android:id="@+id/tvPendingSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 pending"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Recent Pending Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp"
                android:text="RECENT PENDING REQUESTS"
                android:textColor="#1B3A2D"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="@font/inter_bold"/>

            <!-- Empty State -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutEmptyPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textColor="#D0D0D0"
                        android:textSize="28sp"
                        android:fontFamily="@font/dm_serif"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="No pending requests."
                        android:textColor="#BBBBBB"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_regular"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dynamic Pending List -->
            <LinearLayout
                android:id="@+id/layoutPendingList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:orientation="vertical"
                android:visibility="gone"/>

            <!-- Log Out -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↪"
                    android:textColor="#E53E3E"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Log Out"
                    android:textColor="#E53E3E"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_bold"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#1B3A2D"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Dashboard"
                android:textColor="#1B3A2D"
                android:textSize="10sp"
                android:fontFamily="@font/inter_bold"/>
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/shape_circle"
                android:backgroundTint="#1B3A2D"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navManageSlots"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                app:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Manage Slots"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRequests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_clipboard"
                app:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Requests"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Profile"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>