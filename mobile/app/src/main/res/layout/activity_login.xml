<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@color/background"
            android:elevation="3dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/wellcheck_logo"
                    android:scaleType="centerInside"
                    android:contentDescription="WellCheck Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WellCheck"
                    android:layout_marginStart="8dp"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:letterSpacing="-0.03" />

            </LinearLayout>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Login"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/text_dark"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                app:cornerRadius="10dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0F000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="48dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back!"
                    android:textSize="26sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:gravity="center"
                    android:letterSpacing="-0.03"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sign in to your WellCheck account"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="28dp" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_error"
                    android:textColor="@color/error_red"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="johndoe@gmail.com"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_dark"
                    android:textColorHint="#AAAAAA"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="24dp">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Enter your password"
                        android:inputType="textPassword"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="52dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_dark"
                        android:textColorHint="#AAAAAA" />

                    <ImageButton
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="end|center_vertical"
                        android:src="@drawable/ic_eye"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Toggle password visibility" />

                </FrameLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Sign In"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/green_primary"
                    android:stateListAnimator="@null"
                    app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Medium"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#DDDDDD" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="or"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textColor="#AAAAAA"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#DDDDDD" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Sign in with Google"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_dark"
                    android:backgroundTint="@color/white"
                    android:stateListAnimator="@null"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconTint="@null"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1.5dp"
                    app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Medium"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/tvSignUp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/green_primary" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>