<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F7F4">

    <!-- Topbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <!-- Brand -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text=""
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_logo"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WellCheck"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Portal"
                    android:textSize="11sp"
                    android:textColor="#888888" />

            </LinearLayout>

        </LinearLayout>

        <!-- User info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#333333"
                android:layout_marginEnd="8dp"
                android:maxWidth="150dp"
                android:ellipsize="end"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="S"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Good Morning!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvGreetingSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Here's your wellness overview for today"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="20dp" />

            <!-- Wellness Tip Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S WELLNESS TIP"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1F7A5A"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&quot;Take 5 minutes today to breathe deeply and reset your focus.&quot;"
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingMultiplier="1.5"
                    android:fontFamily="serif" />

            </LinearLayout>

            <!-- Upcoming Appointment Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Upcoming Appointment"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No upcoming appointments."
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>

            <!-- Quick Actions Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="+ Book a new appointment"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1F7A5A"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="View my appointments"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:backgroundTint="#FFFFFF"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom logout bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↪  Log Out"
            android:textSize="14sp"
            android:textColor="#E53E3E"
            android:padding="4dp" />

    </LinearLayout>

</LinearLayout>