<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@color/background"
            android:elevation="3dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/wellcheck_logo"
                    android:scaleType="centerInside"
                    android:contentDescription="WellCheck Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WellCheck"
                    android:layout_marginStart="8dp"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:letterSpacing="-0.03" />

            </LinearLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Login"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/text_dark"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                app:cornerRadius="10dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0F000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot"
                    android:layout_marginEnd="7dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guidance &amp; Wellness Platform"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Book counseling"
                android:textSize="34sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="appointments "
                    android:textSize="34sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:letterSpacing="-0.03" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="securely"
                    android:textSize="34sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="-0.03" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect with professional counselors who understand student life. Schedule appointments that fit your schedule and take control of your mental wellness journey."
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_gray"
                android:lineSpacingMultiplier="1.65"
                android:layout_marginBottom="28dp" />

            <Button
                android:id="@+id/btnSignUpStudent"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign Up as Student"
                android:textSize="15sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/green_primary"
                android:stateListAnimator="@null"
                app:cornerRadius="12dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnSignUpCounselor"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign Up as Counselor"
                android:textSize="15sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_dark"
                android:backgroundTint="@color/white"
                android:stateListAnimator="@null"
                app:cornerRadius="12dp"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confidential"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"
                        android:textColor="#999999" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24/7"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking access"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"
                        android:textColor="#999999" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fast"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Approval process"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"
                        android:textColor="#999999" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_green"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card_icon_white"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="20sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Secure &amp; Confidential"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All appointments and conversations are protected with enterprise-grade encryption."
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textColor="#CCFCE8"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card_icon_green"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="20sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Easy Scheduling"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Browse available counselors and book your slot in just a few clicks."
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_gray"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_card_icon_green"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="20sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instant Notifications"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Get notified via email when your appointment is approved or rejected."
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_gray"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HOW IT WORKS"
                android:textSize="11sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/green_primary"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get support in 3 simple steps"
                android:textSize="24sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="1"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:gravity="center"
                    android:background="@drawable/bg_step_number"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="top">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Create an account"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sign up as a student and complete your profile to get started."
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_gray"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="2"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:gravity="center"
                    android:background="@drawable/bg_step_number"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Browse counselors"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Find a counselor that fits your needs and view their available slots."
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_gray"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="3"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:gravity="center"
                    android:background="@drawable/bg_step_number"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Book &amp; get support"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Submit your booking and wait for confirmation. It's that simple."
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_gray"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/text_dark"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready to get started?"
                android:textSize="26sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join students who are already managing their wellness with WellCheck."
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="#99FFFFFF"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="28dp" />

            <Button
                android:id="@+id/btnFooterCta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Create your free account →"
                android:textSize="15sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/green_primary"
                android:stateListAnimator="@null"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111111"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2026 WellCheck. All rights reserved."
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                android:textColor="#55FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>