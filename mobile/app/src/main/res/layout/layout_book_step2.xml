<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvStep2Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Additional Information"
            android:textColor="#1A1A1A"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvStep2Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="School ID verification and appointment note."
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- School ID: OK state -->
        <LinearLayout
            android:id="@+id/layoutIdOk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_id_ok"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                app:tint="#16A34A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="School ID Uploaded"
                    android:textColor="#15803D"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your school ID is on file."
                    android:textColor="#166534"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- School ID: Missing state -->
        <LinearLayout
            android:id="@+id/layoutIdMissing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_id_missing"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_warning"
                app:tint="#D97706" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="School ID Required"
                    android:textColor="#92400E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please upload your school ID in your profile to continue."
                    android:textColor="#78350F"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Appointment Note (Optional)"
            android:textColor="#374151"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:gravity="top|start"
            android:hint="Briefly describe what you'd like to discuss..."
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

        <!-- Back / Review buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStep2Back"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="Back"
            android:textColor="@color/green_dark"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/green_dark"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStep2Review"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:text="Review Booking"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/green_dark"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>